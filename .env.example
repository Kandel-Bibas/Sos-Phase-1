# CLaRa Legal Analysis System - Environment Configuration
# Copy this file to .env and fill in your values

# LLM Provider Configuration
# Choose either 'anthropic' or 'openai'
LLM_PROVIDER=anthropic

# API Keys (set the one for your chosen provider)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# Model Configuration
# For Anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514, etc.
# For OpenAI: gpt-4o, gpt-4-turbo, etc.
COMPRESSION_MODEL=claude-sonnet-4-20250514
CHAT_MODEL=claude-sonnet-4-20250514

# LLM Parameters
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Vector Store Configuration
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=ms_legal_abstracts

# Embedding Model (sentence-transformers model name)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Document Processing
DOCUMENTS_DIR=./documents
CHUNK_SIZE=2000
CHUNK_OVERLAP=200

# Retrieval Settings
RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.3
